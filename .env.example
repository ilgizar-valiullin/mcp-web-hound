# === Search MCP Server — Environment Template ===
# Copy to .env and fill in your keys.

LOG_LEVEL=info
DATA_DIR=./data

# DuckDuckGo (free, no key)
DDG_ENABLED=true
DDG_DELAY_MS=1000
DDG_MAX_PER_MINUTE=10

# Bing (free, no key)
BING_ENABLED=true

# SearXNG (self-hosted)
SEARXNG_ENABLED=false
SEARXNG_URL=http://localhost:8888

# Brave (free: 2000/month)
BRAVE_API_KEY=
BRAVE_DAILY_LIMIT=60

# Tavily (free: 1000/month)
TAVILY_API_KEY=
TAVILY_DAILY_LIMIT=30

# Exa (trial: 1000 queries)
EXA_API_KEY=

# Firecrawl (trial: 500 credits)
FIRECRAWL_API_KEY=

# GitHub Search (optional, 60 req/hr without token)
GITHUB_TOKEN=

# GitLab Search (optional)
GITLAB_TOKEN=

# Budget
BUDGET_MAX_SEARCHES=15
BUDGET_MAX_FETCHES=30
BUDGET_WINDOW_MINUTES=30

# Semantic search (requires @xenova/transformers ~120MB)
SEMANTIC_ENABLED=false
