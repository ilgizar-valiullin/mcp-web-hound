# === MCP Web Hound — Default Configuration ===
# Copy to .env or run mcp-web-hound-configure to generate.
# Lines starting with # are comments — removed when configure updates a value.
# Each KEY=VALUE below is the server default; uncomment + edit to override.

# --- Server ---
# Logging verbosity
# LOG_LEVEL=info
# Directory for cache database (relative paths resolve from CWD)
# DATA_DIR=./data
# SQLite database file name inside DATA_DIR
# DB_FILENAME=search.db

# --- Search Providers ---
# Enable DuckDuckGo search (free, no key)
# DDG_ENABLED=true
# Enable Bing search (free, no key)
# BING_ENABLED=true
# Enable Startpage / Google mirror (free, no key)
# STARTPAGE_ENABLED=true
# Enable Brave Web HTML scrape (free, no key)
# BRAVE_WEB_ENABLED=true

# --- API Keys ---
# API key for Brave Search API (2000 queries/month free)
# BRAVE_API_KEY=
# Max Brave Search API queries per day
# BRAVE_DAILY_LIMIT=60
# API key for Tavily Search (1000 queries/month free)
# TAVILY_API_KEY=
# Max Tavily queries per day
# TAVILY_DAILY_LIMIT=30
# API key for Exa Search (trial 1000 queries)
# EXA_API_KEY=
# API key for Firecrawl (trial 500 credits)
# FIRECRAWL_API_KEY=

# --- Platform Tokens ---
# GitHub personal access token (optional, 60 req/hr without)
# GITHUB_TOKEN=
# GitLab personal access token with read_api scope
# GITLAB_TOKEN=

# --- Search Engine ---
# Comma-separated provider priority list (tried top to bottom)
# PROVIDER_ORDER=startpage,ddg,brave_web,bing,brave_api,tavily,exa,firecrawl
# Run providers in parallel or fall through one by one
# PROVIDER_EXECUTION_MODE=parallel
# Max providers to query simultaneously
# MAX_PARALLEL_PROVIDERS=2
# Max results returned after reranking
# MAX_RESULTS_AFTER_RERANK=10
# Per-provider search timeout in milliseconds
# SEARCH_TIMEOUT_MS=15000

# --- Budget ---
# Max searches allowed per budget window
# BUDGET_MAX_SEARCHES=15
# Max page fetches allowed per budget window
# BUDGET_MAX_FETCHES=30
# Budget window duration in minutes
# BUDGET_WINDOW_MINUTES=30

# --- Cache ---
# Max cache database size in MB (0 = unlimited)
# CACHE_MAX_SIZE_MB=500
# Interval between automatic cache size checks (minutes)
# CACHE_EVICTION_INTERVAL_MIN=30
# Cache entry time-to-live in minutes (1440 = 24h)
# CACHE_TTL_MINUTES=1440

# --- AI Features ---
# Enable semantic search with embeddings (~120MB model download)
# SEMANTIC_ENABLED=true
# HuggingFace model for text embeddings
# EMBEDDING_MODEL=multilingual-e5-small
# Embedding vector dimension (must match model output)
# EMBEDDING_DIMENSION=384
# Cosine similarity threshold for semantic dedup
# SEMANTIC_THRESHOLD=0.92
# HuggingFace model for NLI-based intent classification
# INTENT_CLASSIFIER_MODEL=Xenova/nli-deberta-v3-xsmall
# Enable cross-encoder reranking for result relevance
# RERANK_ENABLED=true

# --- Deduplication ---
# Window in minutes for deduplicating identical queries
# SESSION_DEDUP_WINDOW_MINUTES=5
# Extra minutes to extend dedup window on new activity
# SESSION_DEDUP_STRETCH_MINUTES=0

# --- DuckDuckGo Tuning ---
# Delay between DuckDuckGo requests in milliseconds
# DDG_DELAY_MS=1000
# Max DuckDuckGo requests per minute
# DDG_MAX_PER_MINUTE=10
# DuckDuckGo results per page
# DDG_RESULTS_PER_PAGE=10
# Max DuckDuckGo pages to scrape
# DDG_MAX_PAGES=1

# --- Bing Tuning ---
# Bing results per page
# BING_RESULTS_PER_PAGE=10
# Max Bing pages to scrape
# BING_MAX_PAGES=1

# --- Rate Limits (RPM / RPD / RPMONTH) ---
# DuckDuckGo max requests per minute
# DDG_RPM=10
# DuckDuckGo max requests per day
# DDG_RPD=200
# DuckDuckGo max requests per month
# DDG_RPMONTH=6000
# Bing max requests per minute
# BING_RPM=15
# Bing max requests per day
# BING_RPD=60
# Bing max requests per month
# BING_RPMONTH=1800
# Startpage max requests per minute
# STARTPAGE_RPM=10
# Startpage max requests per day
# STARTPAGE_RPD=200
# Startpage max requests per month
# STARTPAGE_RPMONTH=6000
# Brave Search API max requests per minute
# BRAVE_RPM=15
# Brave Search API max requests per day
# BRAVE_RPD=60
# Brave Search API max requests per month
# BRAVE_RPMONTH=2000
# Brave Web scrape max requests per minute
# BRAVE_WEB_RPM=10
# Brave Web scrape max requests per day
# BRAVE_WEB_RPD=100
# Brave Web scrape max requests per month
# BRAVE_WEB_RPMONTH=6000
# Tavily max requests per minute
# TAVILY_RPM=10
# Tavily max requests per day
# TAVILY_RPD=30
# Tavily max requests per month
# TAVILY_RPMONTH=1000
# Exa max requests per minute
# EXA_RPM=10
# Exa max requests per day
# EXA_RPD=30
# Exa max requests per month
# EXA_RPMONTH=1000
# Firecrawl max requests per minute
# FIRECRAWL_RPM=5
# Firecrawl max requests per day
# FIRECRAWL_RPD=15
# Firecrawl max requests per month
# FIRECRAWL_RPMONTH=500
